{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug DDNS updater",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "preLaunchTask": "build",
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}/dist/app.js"
    },
    {
      "name": "Debug optional MCP HTTP server",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "preLaunchTask": "build",
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}/dist/mcp.js",
      "args": ["--transport=http"]
    }
  ]
}
