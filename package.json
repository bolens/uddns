{
  "name": "uddns",
  "version": "2.0.0",
  "private": true,
  "description": "uDDNS — micro multi-provider Dynamic DNS updater (Cloudflare, DuckDNS, No-IP, Dynu, Namecheap, DynDNS, Route53, Porkbun, Hetzner, DigitalOcean)",
  "license": "MIT",
  "author": "Michael Bolens",
  "bin": {
    "uddns": "./dist/cli.js"
  },
  "type": "module",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node --env-file-if-exists=.env dist/app.js",
    "mcp": "node --env-file-if-exists=.env dist/mcp.js",
    "mcp:http": "node --env-file-if-exists=.env dist/mcp.js --transport=http",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "vp check",
    "test": "vp test",
    "test:coverage": "vp test -- --coverage",
    "test:live": "RUN_LIVE_TESTS=1 vp test tests/live -- --testTimeout=35000",
    "test:parallel": "node scripts/test-parallel.mjs",
    "config:check": "node --env-file-if-exists=.env dist/app.js --check-config",
    "scaffold:provider": "node scripts/scaffold-provider.mjs",
    "docs:check": "vp test tests/docs.test.ts",
    "lean:check": "fallow dead-code --fail-on-issues",
    "audit": "fallow audit",
    "deadcode": "fallow dead-code",
    "verify": "vp check && node scripts/test-parallel.mjs && vp run build && fallow dead-code --fail-on-issues",
    "fmt": "vp fmt",
    "lint": "vp lint",
    "prepare": "vp config"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.3",
    "@vitest/coverage-v8": "^4.1.10",
    "fallow": "^3.6.0",
    "typescript": "^7.0.2",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.13.1",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": "24.18.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.13.1"
}
