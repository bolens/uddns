{
  "name": "ddns-updater",
  "version": "2.0.0",
  "private": true,
  "description": "Multi-provider DDNS updater (Cloudflare, DuckDNS, No-IP, Dynu, Namecheap, DynDNS)",
  "license": "ISC",
  "author": "Michael Bolens",
  "type": "module",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node --env-file-if-exists=.env dist/app.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "vp check",
    "test": "vp test",
    "test:coverage": "vp test -- --coverage",
    "test:parallel": "node scripts/test-parallel.mjs",
    "docs:check": "vp test tests/docs.test.ts",
    "lean:check": "fallow dead-code --fail-on-issues",
    "audit": "fallow audit",
    "deadcode": "fallow dead-code",
    "verify": "vp check && node scripts/test-parallel.mjs && vp run build && fallow dead-code --fail-on-issues",
    "fmt": "vp fmt",
    "lint": "vp lint",
    "prepare": "vp config"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "fallow": "^3.6.0",
    "typescript": "^7.0.2",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.13.1",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": "24.18.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.13.1"
}
