# uDDNS configuration reference (see docs/providers.md and docs/mcp.md)
UDDNS_PROVIDER=cloudflare
UDDNS_INTERVAL=900000
# Per-host checkpoints survive restarts. Set empty to disable persistence.
UDDNS_STATE_FILE=.uddns-state.json
# Cycle history ring buffer. Set empty to disable.
UDDNS_HISTORY_FILE=.uddns-history.json
# error | warn | info (default) | debug
UDDNS_LOG_LEVEL=info
# text (default) | json
UDDNS_LOG_FORMAT=text
# Optional generic token fallback; prefer the provider-specific token below.
# UDDNS_TOKEN=

# One host:
# UDDNS_HOST=home.example.com
# Or multiple hosts (comma or space separated):
UDDNS_HOSTS=home.example.com,vpn.example.com,api.example.com
# Temporarily skip hosts without removing them from UDDNS_HOSTS
# UDDNS_DISABLED_HOSTS=vpn.example.com

# Public IP discovery / policy
# UDDNS_IP_FAMILY=dual
# keep: reuse the previous address when a family fails discovery (default)
# clear: omit that family from the next upsert — does NOT delete existing DNS records
# UDDNS_IP_MISSING=keep
# UDDNS_IP_HTTPS_V4=https://ipv4.icanhazip.com,https://api.ipify.org
# UDDNS_IP_HTTPS_V6=https://ipv6.icanhazip.com,https://api64.ipify.org
# Off by default (forgeable on-path). Enable only when HTTPS echo is unreachable.
# UDDNS_IP_DNS_FALLBACK=false
# UDDNS_IP_TIMEOUT_MS=5000

# Notifications (HTTPS only)
# UDDNS_NOTIFY_WEBHOOK_URL=https://example.com/hook
# UDDNS_NOTIFY_NTFY_URL=https://ntfy.sh/my-topic
# UDDNS_NOTIFY_SLACK_URL=https://hooks.slack.com/services/...
# UDDNS_NOTIFY_DISCORD_URL=https://discord.com/api/webhooks/...
# UDDNS_NOTIFY_ON=change,error

# Optional OpenTelemetry spans (no-op unless an OTel SDK is registered)
# UDDNS_OTEL=false

# Health / metrics side server (off by default)
# UDDNS_HEALTH=false
# UDDNS_HEALTH_HOST=127.0.0.1
# UDDNS_HEALTH_PORT=3924
# Required when UDDNS_HEALTH_HOST is not loopback; also gates /metrics and /events
# UDDNS_HEALTH_AUTH_TOKEN=
# Required with AUTH_TOKEN when UDDNS_HEALTH_HOST is not loopback (mirrors MCP)
# UDDNS_HEALTH_TLS_CERT=
# UDDNS_HEALTH_TLS_KEY=
# UDDNS_METRICS=false

# Multi-account YAML (optional; see examples/uddns.multi.yaml)
# UDDNS_CONFIG_FILE=

# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
# CLOUDFLARE_ZONE_NAME=example.com
# CLOUDFLARE_RECORD_NAME=home.example.com
# CLOUDFLARE_RECORD_ID=
# CLOUDFLARE_PROXIED=false
# CLOUDFLARE_TTL=1
# CLOUDFLARE_CREATE_IF_MISSING=true

# DuckDNS
# UDDNS_PROVIDER=duckdns
# DUCKDNS_TOKEN=
# DUCKDNS_DOMAINS=myhost,otherhost
# or: UDDNS_HOSTS=myhost,otherhost

# No-IP / Dynu
# UDDNS_PROVIDER=noip
# UDDNS_USER=
# UDDNS_PASS=
# UDDNS_HOSTS=host1.ddns.net,host2.ddns.net

# Namecheap
# UDDNS_PROVIDER=namecheap
# NAMECHEAP_HOST=home
# NAMECHEAP_DOMAIN=example.com
# NAMECHEAP_PASSWORD=
# UDDNS_HOSTS=home,vpn,api
# (or FQDNs: UDDNS_HOSTS=home.example.com,vpn.example.com)


# DynDNS-compatible
# UDDNS_PROVIDER=dyndns
# DYNDNS_UPDATE_URL=https://members.dyndns.org/nic/update

# AWS Route53
# UDDNS_PROVIDER=route53
# ROUTE53_ACCESS_KEY_ID=
# ROUTE53_SECRET_ACCESS_KEY=
# ROUTE53_HOSTED_ZONE_ID=
# ROUTE53_REGION=us-east-1
# ROUTE53_TTL=300
# ROUTE53_CREATE_IF_MISSING=true

# Porkbun
# UDDNS_PROVIDER=porkbun
# PORKBUN_API_KEY=
# PORKBUN_SECRET_KEY=
# PORKBUN_DOMAIN=example.com

# Hetzner DNS
# UDDNS_PROVIDER=hetzner
# HETZNER_API_TOKEN=
# HETZNER_ZONE_ID=
# HETZNER_ZONE_NAME=example.com

# DigitalOcean
# UDDNS_PROVIDER=digitalocean
# DIGITALOCEAN_API_TOKEN=
# DIGITALOCEAN_DOMAIN=example.com

# Gandi LiveDNS
# UDDNS_PROVIDER=gandi
# GANDI_API_TOKEN=
# GANDI_DOMAIN=example.com
# GANDI_TTL=300

# Akamai Connected Cloud (Linode DNS)
# UDDNS_PROVIDER=linode
# LINODE_API_TOKEN=
# LINODE_DOMAIN_ID=
# LINODE_DOMAIN=example.com
# LINODE_TTL=300

# OVHcloud
# UDDNS_PROVIDER=ovh
# OVH_ENDPOINT=eu
# OVH_APPLICATION_KEY=
# OVH_APPLICATION_SECRET=
# OVH_CONSUMER_KEY=
# OVH_ZONE=example.com
# OVH_TTL=300

# bunny.net DNS
# UDDNS_PROVIDER=bunny
# BUNNY_API_KEY=
# BUNNY_ZONE_ID=
# BUNNY_DOMAIN=example.com
# BUNNY_TTL=300

# Contabo DNS
# UDDNS_PROVIDER=contabo
# CONTABO_CLIENT_ID=
# CONTABO_CLIENT_SECRET=
# CONTABO_API_USER=
# CONTABO_API_PASSWORD=
# CONTABO_ZONE=example.com
# CONTABO_TTL=300

# Optional MCP server (stdio for Cursor; http for daemon / remote)
# UDDNS_MCP_TRANSPORT=stdio
# UDDNS_MCP_HOST=127.0.0.1
# UDDNS_MCP_PORT=3923
# UDDNS_MCP_AUTH_TOKEN=
# UDDNS_MCP_TLS_CERT=
# UDDNS_MCP_TLS_KEY=
