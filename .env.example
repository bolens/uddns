DDNS_PROVIDER=cloudflare
DDNS_INTERVAL=900000
# error | warn | info (default) | debug
DDNS_LOG_LEVEL=info
# Optional generic token fallback; prefer the provider-specific token below.
# DDNS_TOKEN=

# One host:
# DDNS_HOST=home.example.com
# Or multiple hosts (comma or space separated):
DDNS_HOSTS=home.example.com,vpn.example.com,api.example.com

# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
# CLOUDFLARE_ZONE_NAME=example.com
# CLOUDFLARE_RECORD_NAME=home.example.com
# CLOUDFLARE_RECORD_ID=
# CLOUDFLARE_PROXIED=false
# CLOUDFLARE_TTL=1
# CLOUDFLARE_CREATE_IF_MISSING=true

# DuckDNS
# DDNS_PROVIDER=duckdns
# DUCKDNS_TOKEN=
# DUCKDNS_DOMAINS=myhost,otherhost
# or: DDNS_HOSTS=myhost,otherhost

# No-IP / Dynu
# DDNS_PROVIDER=noip
# DDNS_USER=
# DDNS_PASS=
# DDNS_HOSTS=host1.ddns.net,host2.ddns.net

# Namecheap
# DDNS_PROVIDER=namecheap
# NAMECHEAP_HOST=home
# NAMECHEAP_DOMAIN=example.com
# NAMECHEAP_PASSWORD=
# DDNS_HOSTS=home,vpn,api
# (or FQDNs: DDNS_HOSTS=home.example.com,vpn.example.com)


# DynDNS-compatible
# DDNS_PROVIDER=dyndns
# DYNDNS_UPDATE_URL=https://members.dyndns.org/nic/update
